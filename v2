cat <<'MONITOREOF' > netflix-monitor.js
const { ImapFlow } = require('imapflow');
const { simpleParser } = require('mailparser');
const axios = require('axios');
const fs = require('fs');
const path = require('path');
const EventEmitter = require('events');

const NETFLIX_ACCOUNTS_FILE = path.join(__dirname, 'data/netflix_accounts.json');
const CONFIG_PATH = path.join(__dirname, 'config.json');

function getConfig() {
    return JSON.parse(fs.readFileSync(CONFIG_PATH));
}

class NetflixMonitor extends EventEmitter {
    constructor(io) {
        super();
        this.io = io;
        this.accounts = [];
        this.interval = null;
        this.loadAccounts();
        this.startMonitoring();
    }

    loadAccounts() {
        try {
            if (fs.existsSync(NETFLIX_ACCOUNTS_FILE)) {
                const data = fs.readFileSync(NETFLIX_ACCOUNTS_FILE, 'utf8');
                this.accounts = JSON.parse(data);
            } else {
                this.accounts = [];
                fs.writeFileSync(NETFLIX_ACCOUNTS_FILE, JSON.stringify([]));
            }
        } catch (err) {
            console.error('Error cargando cuentas de Netflix:', err);
            this.accounts = [];
        }
    }

    saveAccounts() {
        try {
            fs.writeFileSync(NETFLIX_ACCOUNTS_FILE, JSON.stringify(this.accounts, null, 2));
        } catch (err) {
            console.error('Error guardando cuentas de Netflix:', err);
        }
    }

    addAccount(email, password) {
        const exists = this.accounts.some(acc => acc.email === email);
        if (exists) return false;

        const newAccount = {
            email,
            password,
            active: true,
            lastCheck: null,
            lastResult: null,
            lastError: null,
            lastCodes: []
        };
        this.accounts.push(newAccount);
        this.saveAccounts();
        return true;
    }

    deleteAccount(email) {
        this.accounts = this.accounts.filter(acc => acc.email !== email);
        this.saveAccounts();
    }

    getAccounts() {
        return this.accounts.map(acc => ({
            email: acc.email,
            active: acc.active,
            lastCheck: acc.lastCheck,
            lastResult: acc.lastResult,
            lastError: acc.lastError,
            lastCodes: acc.lastCodes || []
        }));
    }

    extractNetflixInfo(parsed) {
        const content = parsed.html || parsed.textAsHtml || parsed.text || '';
        const links = [];
        const codes = [];

        const linkRegex = /https?:\/\/(?:www\.)?netflix\.com\/[^\s"']*?(?:UpdateHome|confirm|verify|updatehome)[^\s"']*/gi;
        const linkMatches = content.match(linkRegex);
        if (linkMatches) {
            linkMatches.forEach(link => links.push(link));
        }

        const codeRegex = /\b(\d{6,8})\b/g;
        const codeMatches = content.match(codeRegex);
        if (codeMatches) {
            codeMatches.forEach(code => codes.push(code));
        }

        return { links, codes };
    }

    async checkAccount(account) {
        if (!account.active) return;

        const client = new ImapFlow({
            host: 'imap.gmail.com',
            port: 993,
            secure: true,
            auth: {
                user: account.email,
                pass: account.password
            },
            logger: false
        });

        try {
            await client.connect();
            console.log(`📬 Conectado a Gmail para ${account.email}`);

            let lock = await client.getMailboxLock('INBOX');
            try {
                const since = new Date();
                since.setDate(since.getDate() - 1);
                const searchQuery = ['UNSEEN', 'FROM', 'info@account.netflix.com', 'SINCE', since.toISOString().split('T')[0]];
                const messages = await client.search(searchQuery, { uid: true });

                if (messages.length === 0) {
                    account.lastCheck = new Date().toISOString();
                    account.lastResult = 'No hay correos nuevos de Netflix';
                    account.lastError = null;
                    account.lastCodes = [];
                    console.log(`📭 No hay correos de Netflix para ${account.email}`);
                } else {
                    console.log(`📨 Se encontraron ${messages.length} correos de Netflix para ${account.email}`);
                    let allLinks = [];
                    let allCodes = [];

                    for (const uid of messages) {
                        const message = await client.fetchOne(uid, { source: true });
                        const parsed = await simpleParser(message.source);
                        const { links, codes } = this.extractNetflixInfo(parsed);

                        if (links.length > 0 || codes.length > 0) {
                            allLinks = allLinks.concat(links);
                            allCodes = allCodes.concat(codes);

                            for (const link of links) {
                                try {
                                    await axios.get(link, { timeout: 10000 });
                                    console.log(`✅ Enlace procesado: ${link}`);
                                } catch (err) {
                                    console.error(`❌ Error al acceder al enlace ${link}:`, err.message);
                                }
                            }

                            await client.messageFlagsAdd(uid, ['\\Seen']);
                        }
                    }

                    if (allLinks.length > 0 || allCodes.length > 0) {
                        account.lastResult = `Procesados ${allLinks.length} enlaces, ${allCodes.length} códigos`;
                        account.lastCodes = allCodes.slice(0, 5);
                    } else {
                        account.lastResult = 'Correo sin enlaces ni códigos';
                        account.lastCodes = [];
                    }
                    account.lastError = null;
                }
            } finally {
                lock.release();
            }

            await client.logout();
        } catch (err) {
            console.error(`❌ Error revisando cuenta ${account.email}:`, err);
            account.lastError = err.message;
        } finally {
            account.lastCheck = new Date().toISOString();
            this.saveAccounts();
            this.emit('update', this.getAccounts());
            if (this.io) {
                this.io.emit('netflix_accounts_update', this.getAccounts());
            }
        }
    }

    async checkAllAccounts() {
        console.log('🔍 Iniciando revisión de cuentas Netflix...');
        for (const account of this.accounts) {
            await this.checkAccount(account);
        }
    }

    startMonitoring() {
        if (this.interval) clearInterval(this.interval);
        const config = getConfig();
        const intervalSeconds = config.netflixInterval || 300;
        this.interval = setInterval(() => {
            this.checkAllAccounts().catch(console.error);
        }, intervalSeconds * 1000);
        console.log(`📡 Monitoreo de Netflix iniciado, intervalo: ${intervalSeconds} segundos`);
    }

    stopMonitoring() {
        if (this.interval) {
            clearInterval(this.interval);
            this.interval = null;
            console.log('🛑 Monitoreo de Netflix detenido');
        }
    }

    updateInterval(newSeconds) {
        if (this.interval) {
            clearInterval(this.interval);
            this.interval = setInterval(() => {
                this.checkAllAccounts().catch(console.error);
            }, newSeconds * 1000);
            console.log(`📡 Intervalo de monitoreo actualizado a ${newSeconds} segundos`);
        }
    }
}

module.exports = NetflixMonitor;
MONITOREOF

