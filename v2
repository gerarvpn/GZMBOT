function scheduleLearningCleanup(period) {
    let cronExpression = '';
    switch (period) {
        case '24h': cronExpression = '0 0 * * *'; break;
        case '2d': cronExpression = '0 0 */2 * *'; break;
        case '7d': cronExpression = '0 0 * * 0'; break;
        case '30d': cronExpression = '0 0 1 * *'; break;
        default: return null;
    }
    return cron.schedule(cronExpression, () => {
        const db = getDB();
        if (db.learning && db.learning.length > 0) {
            db.learning = [];
            saveDB(db);
            io.emit('data_update', db);
            console.log('🧹 Limpieza automática de aprendizaje ejecutada -', nowRD().format('DD/MM/YYYY HH:mm:ss'));
        }
    }, {
        scheduled: true,
        timezone: TZ
    });
}

let cleanupCron = null;
function updateCleanupSchedule(period) {
    if (cleanupCron) {
        cleanupCron.stop();
        cleanupCron = null;
    }
    if (period !== 'never') {
        cleanupCron = scheduleLearningCleanup(period);
    }
}

