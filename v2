                            </div>
                            <p class="text-sm text-zinc-400 mt-1 flex items-center gap-1"><i data-lucide="phone" class="w-3 h-3"></i> ${esc(r.phone)}</p>
                            <p class="text-sm text-zinc-300 mt-2 preserve-whitespace flex items-start gap-1"><i data-lucide="message-square" class="w-3 h-3 mt-1 flex-shrink-0"></i> ${esc(r.message)}</p>
                            <div class="flex flex-wrap gap-2 mt-3">
                                <span class="reminder-tag"><i data-lucide="repeat" class="w-3 h-3"></i> ${r.freq}</span>
                                <span class="reminder-tag"><i data-lucide="calendar" class="w-3 h-3"></i> ${formatReminderDate(r.date)}</span>
                            </div>
                        </div>
                    </div>
                </div>`
            ).join('');

            document.getElementById('l-excl').innerHTML = (db.excluded || []).map((e,i) =>
                '<div class="glass p-4 rounded-xl flex justify-between items-center gap-2"><span class="text-sm break-all flex items-center gap-2"><i data-lucide="user-x" class="w-4 h-4 text-red-400"></i> '+esc(e.name)+' ('+esc(e.phone)+')</span><button onclick="delE('+i+')" class="text-red-500 flex-shrink-0 p-2 hover:bg-red-500/10 rounded-lg transition"><i data-lucide="user-minus" class="w-4 h-4"></i></button></div>'
            ).join('');

