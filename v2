                                    <button onclick="editR(${i})" class="text-zinc-400 hover:text-white p-1"><i data-lucide="edit-3" class="w-4 h-4"></i></button>
                                    <button onclick="delR(${i})" class="text-red-500 p-1"><i data-lucide="trash-2" class="w-4 h-4"></i></button>
