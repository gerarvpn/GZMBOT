                        <i data-lucide="mail" class="w-5 h-5 text-blue-400"></i>
                        <span class="font-medium">${esc(acc.email)}</span>
                        ${acc.active ? '<span class="badge bg-green-500/10 text-green-400">Activa</span>' : '<span class="badge bg-red-500/10 text-red-400">Inactiva</span>'}
                    </div>
                    <div class="text-sm text-zinc-400">
                        <div class="flex items-center gap-4">
                            <span class="flex items-center gap-1"><i data-lucide="clock" class="w-3 h-3"></i> Última comprobación: ${acc.lastCheck ? new Date(acc.lastCheck).toLocaleString() : 'Nunca'}</span>
                            <span class="flex items-center gap-1"><i data-lucide="check-circle" class="w-3 h-3 text-green-400"></i> ${acc.lastResult || 'Sin resultado'}</span>
                            ${acc.lastError ? `<span class="flex items-center gap-1 text-red-400"><i data-lucide="alert-circle" class="w-3 h-3"></i> ${acc.lastError}</span>` : ''}
