clear
echo " ⚙️ Iniciando Instalación de GZMBOT (Netflix Hogar - Automatización total)"

# Función para detectar OS
detect_os() {
    if [ -f /etc/debian_version ]; then
        echo "debian"
    else
        echo "unknown"
    fi
}

OS=$(detect_os)
if [ "$OS" != "debian" ]; then
