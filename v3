                console.error(`❌ Error enviando mensaje a ${chatId}:`, error.message);
            }
            await new Promise(resolve => setTimeout(resolve, this.intervalMs));
        }

        this.processing = false;
    }

    setInterval(ms) {
        this.intervalMs = ms;
    }

    size() {
        return this.queue.length;
    }
}

