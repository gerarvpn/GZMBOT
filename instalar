            if (confirm("¿Desvincular? Los contadores se reiniciarán.")) {
                const res = await fetch('/api/logout-wa', {method:'POST'});
                if (res.ok) {
                    showToast('WhatsApp desconectado');
                    setTimeout(() => location.reload(), 1500);
                } else {
                    showToast('Error al desconectar', true);
                }
            }
        }

        window.onload = load;
        lucide.createIcons();
    </script>
</body>
</html>
