        dbSqlite.prepare('INSERT INTO reminders (name, phone, message, freq, date) VALUES (?, ?, ?, ?, ?)')
            .run(name, phone, message, freq, date);
    }
    invalidateCache();
    io.emit('data_update', getDB());
    res.json({ ok: true });
});

