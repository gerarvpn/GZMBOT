    <style>
        :root { --bg-primary: #030307; }
        * { margin:0; padding:0; box-sizing:border-box; }
        body { background: var(--bg-primary); color: #f3f4f6; font-family: 'Inter', sans-serif; overflow-x:hidden; }
        .glass-panel { background: rgba(8,8,15,0.85); backdrop-filter: blur(28px) saturate(200%); border:1px solid rgba(255,255,255,0.05); }
        .glass-card { background: rgba(14,14,26,0.6); border:1px solid rgba(255,255,255,0.04); transition: all .35s cubic-bezier(.4,0,.2,1); }
        .glass-card:hover { border-color:rgba(59,130,246,0.35); box-shadow:0 16px 36px -12px rgba(59,130,246,0.25); transform:translateY(-3px); }
        .sidebar-item { display:flex; align-items:center; gap:12px; padding:13px 18px; border-radius:16px; color:#9ca3af; transition:all .25s; cursor:pointer; font-weight:500; margin-bottom:5px; }
        .sidebar-item:hover { background:rgba(255,255,255,0.04); color:#fff; }
