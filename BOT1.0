#!/bin/bash

# ============================================================
# GZMBOT v1.0 - INSTALADOR MODERNO CON BARRA DE PROGRESO
# ============================================================
# - Panel con Workers, gráficos en tiempo real, conexión QR/código
# - Optimizado para VPS 1x1 (1GB RAM)
# - Instalación robusta con resumen de errores
# ============================================================

# --- Configuración de colores y estilos ---
reset_color="\e[0m"
bold="\e[1m"
red="\e[31m"
green="\e[32m"
yellow="\e[33m"
blue="\e[34m"
magenta="\e[35m"
cyan="\e[36m"
white="\e[37m"

# Funciones de ayuda
print_info() {
    echo -e "${blue}[INFO]${reset_color} $1"
}
print_ok() {
    echo -e "${green}[OK]${reset_color} $1"
}
print_warn() {
    echo -e "${yellow}[WARN]${reset_color} $1"
}
print_error() {
    echo -e "${red}[ERROR]${reset_color} $1"
}
print_title() {
    echo -e "${bold}${cyan}$1${reset_color}"
}

# Lista para almacenar errores durante la instalación
declare -a error_list

# Función para ejecutar comandos y capturar errores (no detiene la ejecución)
run_cmd() {
    local cmd="$1"
    local desc="$2"
    echo -ne "${blue}▶${reset_color} $desc ... "
    if eval "$cmd" &> /tmp/gzmbot_cmd_output; then
        echo -e "${green}✔${reset_color}"
        return 0
    else
        echo -e "${red}✘${reset_color}"
        error_list+=("$desc falló: $(cat /tmp/gzmbot_cmd_output | head -n 1)")
        return 1
    fi
}

# Barra de progreso simple (por pasos)
progress_bar() {
    local current=$1
    local total=$2
    local width=40
    local percent=$((current * 100 / total))
    local filled=$((percent * width / 100))
    local empty=$((width - filled))
    echo -ne "\r${cyan}[${green}"
    printf "%${filled}s" | tr ' ' '#'
    printf "%${empty}s" | tr ' ' ' '
    echo -ne "${cyan}] ${percent}%${reset_color}"
}

# --- Inicio del instalador ---
clear
print_title "============================================================="
print_title "  GZMBOT v1.0 - Instalación Definitiva"
print_title "============================================================="
echo ""

# Solicitar credenciales
read -p "$(echo -e ${bold}${white}"Usuario Maestro:"${reset_color}) " ADMIN_USER
read -sp "$(echo -e ${bold}${white}"Contraseña Maestra:"${reset_color}) " ADMIN_PASS
echo ""
read -p "$(echo -e ${bold}${white}"Dominio para el panel (ej. gzmbot.com):"${reset_color}) " DOMAIN

if [ -z "$DOMAIN" ]; then
    print_error "Debes ingresar un dominio válido."
    exit 1
fi

# --- Inicio de la instalación ---
total_steps=14
current_step=0

# 1. Actualizar paquetes
current_step=$((current_step + 1))
progress_bar $current_step $total_steps
print_info " Actualizando paquetes..."
run_cmd "sudo apt-get update -qq" "Actualización de paquetes"

# 2. Instalar dependencias básicas
current_step=$((current_step + 1))
progress_bar $current_step $total_steps
print_info " Instalando dependencias básicas..."
run_cmd "sudo apt-get install -y -qq nginx certbot python3-certbot-nginx lsof curl wget gnupg2 bc ca-certificates build-essential sqlite3 libsqlite3-dev" "Dependencias básicas"

# 3. Detectar versión de Ubuntu y preparar dependencias de Chromium
current_step=$((current_step + 1))
progress_bar $current_step $total_steps
print_info " Preparando dependencias de Chromium..."
UBUNTU_VERSION=$(lsb_release -rs)
if (( $(echo "$UBUNTU_VERSION >= 24.04" | bc -l) )); then
    DEPENDENCIAS="fonts-liberation libappindicator3-1 libasound2t64 libatk-bridge2.0-0 libatk1.0-0 libc6 libcairo2 libcups2 libdbus-1-3 libexpat1 libfontconfig1 libgbm1 libgcc-s1 libglib2.0-0 libgtk-3-0 libnspr4 libnss3 libpango-1.0-0 libpangocairo-1.0-0 libstdc++6 libx11-6 libx11-xcb1 libxcb1 libxcomposite1 libxcursor1 libxdamage1 libxext6 libxfixes3 libxi6 libxrandr2 libxrender1 libxss1 libxtst6 xdg-utils"
else
    DEPENDENCIAS="fonts-liberation libappindicator3-1 libasound2 libatk-bridge2.0-0 libatk1.0-0 libc6 libcairo2 libcups2 libdbus-1-3 libexpat1 libfontconfig1 libgbm1 libgcc-s1 libglib2.0-0 libgtk-3-0 libnspr4 libnss3 libpango-1.0-0 libpangocairo-1.0-0 libstdc++6 libx11-6 libx11-xcb1 libxcb1 libxcomposite1 libxcursor1 libxdamage1 libxext6 libxfixes3 libxi6 libxrandr2 libxrender1 libxss1 libxtst6 xdg-utils"
fi
for pkg in $DEPENDENCIAS; do
    run_cmd "sudo apt-get install -y -qq $pkg" "Dependencia: $pkg"
done

# 4. Instalar Google Chrome Stable
current_step=$((current_step + 1))
progress_bar $current_step $total_steps
print_info " Instalando Google Chrome Stable..."
run_cmd "wget -q -O - https://dl.google.com/linux/linux_signing_key.pub | sudo tee /etc/apt/trusted.gpg.d/google.asc > /dev/null && echo 'deb [arch=amd64] http://dl.google.com/linux/chrome/deb/ stable main' | sudo tee /etc/apt/sources.list.d/google-chrome.list && sudo apt-get update -qq && sudo apt-get install -y -qq google-chrome-stable && sudo ldconfig" "Google Chrome Stable"

# 5. Configurar variables de entorno
current_step=$((current_step + 1))
progress_bar $current_step $total_steps
print_info " Configurando variables de entorno..."
export PUPPETEER_EXECUTABLE_PATH=$(which google-chrome-stable)
export PUPPETEER_SKIP_DOWNLOAD=true
export TZ='America/Santo_Domingo'

# 6. Instalar Node.js 20 LTS
current_step=$((current_step + 1))
progress_bar $current_step $total_steps
print_info " Instalando Node.js 20 LTS..."
run_cmd "curl -fsSL https://deb.nodesource.com/setup_20.x | sudo -E bash - > /dev/null 2>&1 && sudo apt-get install -y -qq nodejs" "Node.js 20 LTS"

# 7. Actualizar npm
current_step=$((current_step + 1))
progress_bar $current_step $total_steps
print_info " Actualizando npm..."
run_cmd "sudo npm install -g npm@latest --quiet" "npm actualizado"

# 8. Configurar zona horaria
current_step=$((current_step + 1))
progress_bar $current_step $total_steps
print_info " Configurando zona horaria..."
sudo timedatectl set-timezone America/Santo_Domingo 2>/dev/null || true

# 9. Crear directorios
current_step=$((current_step + 1))
progress_bar $current_step $total_steps
print_info " Creando directorios..."
mkdir -p $HOME/gzmbot/{views,data,media,backups}
cd $HOME/gzmbot

# 10. Crear config.json
current_step=$((current_step + 1))
progress_bar $current_step $total_steps
print_info " Creando archivo de configuración..."
cat <<EOF > config.json
{
  "adminUser": "$ADMIN_USER",
  "adminPassword": "$ADMIN_PASS",
  "port": 3000,
  "sessionSecret": "$(openssl rand -hex 24)",
  "backupPhone": "",
  "responseDelay": 0,
  "queueInterval": 3000
}
EOF

# 11. Crear app.js (backend)
current_step=$((current_step + 1))
progress_bar $current_step $total_steps
print_info " Generando backend (app.js)..."
# El contenido de app.js es el mismo que la versión 2.1 (con corrección de SQLite y Workers)
cat <<'APPEOF' > app.js
process.env.TZ = 'America/Santo_Domingo';
process.env.NODE_OPTIONS = '--max-old-space-size=128';

const { Client, LocalAuth, MessageMedia } = require('whatsapp-web.js');
const qrcode = require('qrcode');
const express = require('express');
const http = require('http');
const socketIo = require('socket.io');
const session = require('express-session');
const fs = require('fs');
const path = require('path');
const os = require('os');
const { exec } = require('child_process');
const cron = require('node-cron');
const moment = require('moment-timezone');
const multer = require('multer');
const Database = require('better-sqlite3');

const TZ = 'America/Santo_Domingo';
const app = express();
app.set('trust proxy', 1);

const server = http.createServer(app);
const io = socketIo(server, {
    pingTimeout: 60000,
    pingInterval: 25000,
    transports: ['websocket', 'polling']
});

const DB_PATH = path.join(__dirname, 'data/database.sqlite');
const CONFIG_PATH = path.join(__dirname, 'config.json');
const MEDIA_PATH = path.join(__dirname, 'media');
const BACKUP_PATH = path.join(__dirname, 'backups');
const AUTH_PATH = path.join(__dirname, '.wwebjs_auth');

server.listen(3000, '0.0.0.0', () => {
    console.log('🚀 GZMBOT Express activo en puerto 3000.');
});

let dbSqlite;
try {
    dbSqlite = new Database(DB_PATH);
    dbSqlite.pragma('journal_mode = WAL');
    dbSqlite.pragma('synchronous = NORMAL');
    dbSqlite.pragma('temp_store = MEMORY');
    dbSqlite.pragma('busy_timeout = 5000');
    
    dbSqlite.exec(`
        CREATE TABLE IF NOT EXISTS training (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            key TEXT NOT NULL,
            response TEXT NOT NULL,
            mediaPaths TEXT,
            mediaTypes TEXT
        );
        CREATE TABLE IF NOT EXISTS reminders (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            name TEXT NOT NULL,
            phone TEXT NOT NULL,
            message TEXT NOT NULL,
            freq TEXT NOT NULL,
            date TEXT NOT NULL
        );
        CREATE TABLE IF NOT EXISTS excluded (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            name TEXT NOT NULL,
            phone TEXT NOT NULL
        );
        CREATE TABLE IF NOT EXISTS stats (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            replied INTEGER DEFAULT 0,
            total INTEGER DEFAULT 0
        );
        CREATE TABLE IF NOT EXISTS websites (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            name TEXT NOT NULL,
            slug TEXT NOT NULL UNIQUE,
            content TEXT NOT NULL,
            created_at TEXT DEFAULT (datetime('now', 'localtime')),
            updated_at TEXT DEFAULT (datetime('now', 'localtime'))
        );
        CREATE INDEX IF NOT EXISTS idx_reminders_date ON reminders(date);
        CREATE INDEX IF NOT EXISTS idx_excluded_phone ON excluded(phone);
        CREATE INDEX IF NOT EXISTS idx_websites_slug ON websites(slug);
    `);

    const statsRow = dbSqlite.prepare('SELECT COUNT(*) as count FROM stats').get();
    if (statsRow.count === 0) {
        dbSqlite.prepare('INSERT INTO stats (replied, total) VALUES (0, 0)').run();
    }
} catch (sqliteErr) {
    console.error("⚠️ Error inicializando SQLite:", sqliteErr.message);
}

const storage = multer.diskStorage({
    destination: (req, file, cb) => cb(null, MEDIA_PATH),
    filename: (req, file, cb) => cb(null, Date.now() + '-' + file.originalname)
});
const upload = multer({ storage });

app.use(express.json());
app.use(express.urlencoded({ extended: true }));
app.use('/media', express.static(MEDIA_PATH));

const getConfig = () => {
    try {
        return JSON.parse(fs.readFileSync(CONFIG_PATH));
    } catch (e) {
        return { 
            adminUser: "admin", 
            adminPassword: "password", 
            sessionSecret: "fallback_secret", 
            responseDelay: 0, 
            queueInterval: 3000
        };
    }
};

app.use(session({
    secret: getConfig().sessionSecret || 'gzm_secret_default',
    resave: false,
    saveUninitialized: true,
    cookie: { maxAge: 86400000, secure: false }
}));

let cachedDB = null;
let cacheTimestamp = 0;
const CACHE_TTL = 5000;

function getDB() {
    const now = Date.now();
    if (cachedDB && (now - cacheTimestamp) < CACHE_TTL) {
        return cachedDB;
    }
    try {
        const training = dbSqlite.prepare('SELECT * FROM training').all();
        const reminders = dbSqlite.prepare('SELECT * FROM reminders').all();
        const excluded = dbSqlite.prepare('SELECT * FROM excluded').all();
        const stats = dbSqlite.prepare('SELECT * FROM stats LIMIT 1').get() || { replied: 0, total: 0 };
        const websites = dbSqlite.prepare('SELECT * FROM websites ORDER BY id DESC').all();
        cachedDB = { training, reminders, excluded, stats, websites };
        cacheTimestamp = now;
        return cachedDB;
    } catch (e) {
        console.error("Error en getDB:", e);
        return { training: [], reminders: [], excluded: [], stats: { replied: 0, total: 0 }, websites: [] };
    }
}

function invalidateCache() {
    cachedDB = null;
    cacheTimestamp = 0;
}

function updateStats(repliedInc, totalInc) {
    try {
        dbSqlite.prepare('UPDATE stats SET replied = replied + ?, total = total + ?').run(repliedInc, totalInc);
        invalidateCache();
    } catch (e) {}
}

function normalizePhone(phone) {
    if (!phone) return '';
    let clean = phone.split('@')[0];
    clean = clean.replace(/[^\d]/g, '').trim();
    return clean;
}

// Métricas del sistema - cada 5 segundos (tiempo real)
let lastCpu = 0, lastRam = 0;
const cpuCores = os.cpus().length;
function emitSystemStats() {
    try {
        const loadAvg = os.loadavg()[0];
        let cpuUsage = (loadAvg / cpuCores) * 100;
        cpuUsage = Math.min(100, Math.max(0, cpuUsage.toFixed(1)));
        const totalMem = os.totalmem();
        const freeMem = os.freemem();
        const ramUsage = ((totalMem - freeMem) / totalMem) * 100;
        const ramUsagePct = parseFloat(ramUsage.toFixed(1));
        io.emit('sys_stats', { cpu: parseFloat(cpuUsage), ram: ramUsagePct, uptime: os.uptime() });
        lastCpu = cpuUsage;
        lastRam = ramUsagePct;
    } catch (err) {}
}
setInterval(emitSystemStats, 5000);

// Cola inteligente con reintentos (limitada a 500 mensajes)
class MessageQueue {
    constructor(intervalMs = 3000) {
        this.queue = [];
        this.intervalMs = intervalMs;
        this.processing = false;
        this.maxSize = 500;
        this.retryLimit = 2;
    }
    enqueue(chatId, message, options = {}) {
        if (this.queue.length >= this.maxSize) {
            console.warn('⚠️ Cola llena, descartando mensaje.');
            return;
        }
        this.queue.push({ chatId, message, options, attempts: 0 });
        this.process();
    }
    async process() {
        if (this.processing || this.queue.length === 0) return;
        this.processing = true;
        while (this.queue.length > 0) {
            const item = this.queue.shift();
            const { chatId, message, options, attempts } = item;
            try {
                if (isConnected && client) {
                    await client.sendMessage(chatId, message, options);
                } else {
                    throw new Error('No conectado');
                }
            } catch (err) {
                if (attempts < this.retryLimit) {
                    item.attempts++;
                    this.queue.push(item);
                    console.warn(`Reintento ${item.attempts} para ${chatId}`);
                } else {
                    console.error(`❌ Fallo definitivo: ${err.message}`);
                }
            }
            await new Promise(r => setTimeout(r, this.intervalMs));
        }
        this.processing = false;
    }
    setInterval(ms) { this.intervalMs = ms; }
    size() { return this.queue.length; }
}

let client;
let botStatus = "Desconectado";
let lastQR = null;
let lastQRImage = null;
let isConnected = false;
let contacts = [];
let contactsHash = '';
let messageQueue;
let reconnectAttempts = 0;
let reconnectTimeout = null;
let pairingCodeRequested = false;

function scheduleReconnect() {
    if (reconnectTimeout) clearTimeout(reconnectTimeout);
    const delay = Math.min(30000, 1000 * Math.pow(2, reconnectAttempts));
    console.log(`🔄 Reconexión en ${delay/1000}s (intento ${reconnectAttempts+1})`);
    reconnectTimeout = setTimeout(() => {
        reconnectAttempts++;
        cleanSessionAndLaunch();
    }, delay);
}

async function cleanSessionAndLaunch() {
    console.log("🧹 Mantenimiento...");
    try {
        exec('pkill -9 -f "chrome" || true');
        exec('pkill -9 -f "chromium" || true');
        const lockPath = path.join(AUTH_PATH, 'session', 'SingletonLock');
        if (fs.existsSync(lockPath)) fs.unlinkSync(lockPath);
    } catch (e) {}
    setTimeout(() => {
        try {
            launchBot();
        } catch (err) {
            console.error("❌ Error lanzamiento:", err.message);
            botStatus = "Error de inicio";
            io.emit('connection_status', { connected: false, status: botStatus });
            scheduleReconnect();
        }
    }, 1000);
}

async function refreshContacts(force = false) {
    if (!isConnected || !client) return;
    try {
        const rawContacts = await client.getContacts();
        const validContactsMap = new Map();
        const contactsPromises = rawContacts
            .filter(c => c.isMyContact === true && c.isUser && !c.isGroup && !c.isMe)
            .map(async (contact) => {
                try {
                    const formatted = await contact.getFormattedNumber();
                    if (formatted) {
                        const normalized = formatted.replace(/[^0-9]/g, '');
                        if (normalized.length >= 9 && normalized.length <= 15) {
                            return {
                                number: normalized,
                                name: (contact.name || contact.pushname || normalized).trim(),
                                id: contact.id._serialized
                            };
                        }
                    }
                } catch (err) {}
                return null;
            });

        const results = await Promise.all(contactsPromises);
        for (const c of results) {
            if (c && !validContactsMap.has(c.number)) {
                validContactsMap.set(c.number, c);
            }
        }

        const newContacts = Array.from(validContactsMap.values()).sort((a,b) => a.name.localeCompare(b.name));
        const newHash = JSON.stringify(newContacts.map(c => c.number + c.name));
        if (newHash !== contactsHash || force) {
            contacts = newContacts;
            contactsHash = newHash;
            io.emit('contacts_update', contacts);
            console.log(`📞 Contactos guardados actualizados: ${contacts.length} (cambio detectado)`);
        } else {
            contacts = newContacts;
        }
    } catch (e) {
        console.error("❌ Error actualizando contactos:", e.message);
    }
}

setInterval(() => { if (isConnected) refreshContacts(false); }, 300000);

function launchBot() {
    const config = getConfig();
    messageQueue = new MessageQueue(config.queueInterval || 3000);
    pairingCodeRequested = false;

    client = new Client({
        authStrategy: new LocalAuth({ dataPath: AUTH_PATH }),
        webVersionCache: {
            type: 'remote',
            remotePath: 'https://raw.githubusercontent.com/wppconnect-team/wa-version/main/html/2.2412.54.html'
        },
        puppeteer: {
            executablePath: '/usr/bin/google-chrome-stable',
            headless: true,
            userAgent: 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/122.0.0.0 Safari/537.36',
            args: [
                '--no-sandbox',
                '--disable-setuid-sandbox',
                '--disable-dev-shm-usage',
                '--disable-gpu',
                '--no-first-run',
                '--no-zygote',
                '--disable-extensions',
                '--disable-background-timer-throttling',
                '--disable-backgrounding-occluded-windows',
                '--disable-renderer-backgrounding',
                '--disable-accelerated-2d-canvas',
                '--disable-software-rasterizer',
                '--js-flags="--max-old-space-size=128 --expose-gc"',
                '--disable-canvas-path-rendering',
                '--disable-accelerated-video-decode',
                '--disable-component-extensions-with-background-pages'
            ]
        }
    });

    client.on('pairing_code', (code) => {
        console.log(`📲 Código de emparejamiento: ${code}`);
        io.emit('pairing_code', code);
        pairingCodeRequested = false;
    });

    client.on('qr', (qr) => {
        botStatus = "Esperando QR";
        isConnected = false;
        lastQR = qr;
        qrcode.toDataURL(qr, (err, url) => {
            if (!err) {
                lastQRImage = url;
                io.emit('qr_update', url);
            }
            io.emit('connection_status', { connected: false, status: botStatus });
        });
        reconnectAttempts = 0;
        pairingCodeRequested = false;
    });

    client.on('ready', async () => {
        botStatus = "Conectado";
        isConnected = true;
        lastQR = null;
        lastQRImage = null;
        reconnectAttempts = 0;
        pairingCodeRequested = false;
        io.emit('qr_clear');
        io.emit('connection_status', { connected: true, status: botStatus });
        console.log('✅ Conexión establecida.');
        await refreshContacts(true);
    });

    client.on('disconnected', async () => {
        botStatus = "Desconectado";
        isConnected = false;
        lastQR = null;
        lastQRImage = null;
        contacts = [];
        contactsHash = '';
        pairingCodeRequested = false;
        io.emit('contacts_update', []);
        io.emit('qr_clear');
        io.emit('connection_status', { connected: false, status: botStatus });
        scheduleReconnect();
    });

    client.on('message', async (msg) => {
        try {
            if (msg.from === 'status@broadcast') return;
            if (msg.type !== 'chat' && msg.type !== 'image' && msg.type !== 'video') return;
            if (!msg.body || typeof msg.body !== 'string') return;

            let senderNumber = null;
            try {
                const contact = await msg.getContact();
                senderNumber = await contact.getFormattedNumber();
            } catch (err) {
                senderNumber = normalizePhone(msg.from);
            }
            if (!senderNumber) return;
            
            let phone = senderNumber.replace(/[^0-9]/g, '');
            if (phone.length < 9 || phone.length > 15) return;

            const db = getDB();
            if (db.excluded.some(ex => phone.includes(ex.phone))) return;

            const text = msg.body.toLowerCase().trim();
            const trigger = db.training.find(t => {
                const key = t.key.toLowerCase().trim();
                return text === key || text.includes(key);
            });

            if (trigger) {
                const conf = getConfig();
                if (conf.responseDelay > 0) await new Promise(r => setTimeout(r, conf.responseDelay * 1000));
                if (trigger.mediaPaths && JSON.parse(trigger.mediaPaths).length > 0) {
                    const paths = JSON.parse(trigger.mediaPaths);
                    const media = MessageMedia.fromFilePath(paths[0]);
                    messageQueue.enqueue(msg.from, media, { caption: trigger.response });
                } else {
                    messageQueue.enqueue(msg.from, trigger.response);
                }
                updateStats(1, 0);
            } else {
                updateStats(0, 1);
            }
            io.emit('data_update', getDB());
        } catch (e) {
            console.error("⚠️ Error mensaje:", e.message);
        }
    });

    client.initialize().catch(e => {
        console.error("Fallo crítico:", e.message);
        botStatus = "Error de inicio";
        io.emit('connection_status', { connected: false, status: botStatus });
        scheduleReconnect();
    });
}

const sentReminders = new Map();
cron.schedule('* * * * *', () => {
    if (!isConnected) return;
    const db = getDB();
    const currentRD = moment().tz(TZ).format('YYYY-MM-DDTHH:mm');
    let hasChanges = false;
    db.reminders.forEach(rem => {
        if (rem.date === currentRD) {
            const key = `${rem.id}_${currentRD}`;
            const lastSent = sentReminders.get(key);
            if (!lastSent || (Date.now() - lastSent) > 60000) {
                const chatId = rem.phone.includes('@') ? rem.phone : `${rem.phone}@c.us`;
                messageQueue.enqueue(chatId, rem.message);
                sentReminders.set(key, Date.now());
                if (rem.freq && rem.freq !== 'Una vez') {
                    let nextDate = moment.tz(rem.date, TZ);
                    if (rem.freq === 'Diario') nextDate.add(1, 'day');
                    else if (rem.freq === 'Semanal') nextDate.add(7, 'days');
                    else if (rem.freq === 'Mensual') nextDate.add(1, 'month');
                    else if (rem.freq === 'Anual') nextDate.add(1, 'year');
                    dbSqlite.prepare('UPDATE reminders SET date = ? WHERE id = ?').run(nextDate.format('YYYY-MM-DDTHH:mm'), rem.id);
                    hasChanges = true;
                } else {
                    dbSqlite.prepare('DELETE FROM reminders WHERE id = ?').run(rem.id);
                    hasChanges = true;
                }
            }
        }
    });
    if (hasChanges) {
        invalidateCache();
        io.emit('data_update', getDB());
    }
}, { scheduled: true, timezone: TZ });

cleanSessionAndLaunch();

io.on('connection', (socket) => {
    socket.emit('connection_status', { connected: isConnected, status: botStatus });
    if (lastQRImage) socket.emit('qr_update', lastQRImage);
    socket.emit('contacts_update', contacts);
    emitSystemStats();
    let intervalId = setInterval(() => {
        if (messageQueue && socket.connected) {
            socket.emit('queue_size', messageQueue.size());
        }
    }, 10000);
    
    socket.on('force_refresh_contacts', async () => {
        console.log('🔄 Actualización manual de contactos solicitada');
        await refreshContacts(true);
    });
    
    socket.on('disconnect', () => clearInterval(intervalId));
});

// API ROUTING (sin IA, sin learning)
const checkAuth = (req, res, next) => req.session.user ? next() : res.status(401).send("Unauthorized");

app.get('/', (req, res) => req.session.user ? res.sendFile(path.join(__dirname, 'views/index.html')) : res.redirect('/login'));
app.get('/login', (req, res) => res.sendFile(path.join(__dirname, 'views/login.html')));

app.post('/login', (req, res) => {
    const fc = getConfig();
    if (req.body.user === fc.adminUser && req.body.pass === fc.adminPassword) {
        req.session.user = req.body.user;
        res.json({ ok: true });
    } else {
        res.json({ ok: false });
    }
});

app.get('/api/data', checkAuth, (req, res) => {
    const fc = getConfig();
    const db = getDB();
    res.json({
        ...db,
        botStatus,
        qr: lastQR,
        qrImage: lastQRImage,
        isConnected,
        backupPhone: fc.backupPhone || '',
        responseDelay: fc.responseDelay || 0,
        queueInterval: fc.queueInterval || 3000,
        queueSize: messageQueue ? messageQueue.size() : 0,
        serverTime: moment().tz(TZ).format('DD/MM/YYYY hh:mm:ss A'),
        timezone: TZ
    });
});

app.get('/api/contacts', checkAuth, (req, res) => res.json(contacts));

app.post('/api/pairing', checkAuth, async (req, res) => {
    const { phone } = req.body;
    if (!phone) {
        return res.status(400).json({ ok: false, error: 'Número de teléfono requerido' });
    }
    if (!client) {
        return res.status(400).json({ ok: false, error: 'Cliente no inicializado' });
    }
    if (isConnected) {
        return res.status(400).json({ ok: false, error: 'Ya hay una sesión activa' });
    }
    if (pairingCodeRequested) {
        return res.status(400).json({ ok: false, error: 'Ya se solicitó un código, espera el resultado' });
    }
    try {
        pairingCodeRequested = true;
        const cleanPhone = phone.replace(/[^0-9]/g, '');
        if (cleanPhone.length < 9 || cleanPhone.length > 15) {
            pairingCodeRequested = false;
            return res.status(400).json({ ok: false, error: 'Número inválido' });
        }
        const code = await client.requestPairingCode(cleanPhone);
        console.log(`📲 Código generado: ${code}`);
        io.emit('pairing_code', code);
        pairingCodeRequested = false;
        res.json({ ok: true, code });
    } catch (error) {
        console.error('Error en pairing:', error);
        pairingCodeRequested = false;
        res.status(500).json({ ok: false, error: error.message });
    }
});

// === CRUD para Workers (Sitios Web) - CORREGIDO ===
app.get('/api/websites', checkAuth, (req, res) => {
    const db = getDB();
    res.json(db.websites || []);
});

app.post('/api/websites', checkAuth, (req, res) => {
    try {
        let { name, slug, content } = req.body;
        if (!name || !content) {
            return res.status(400).json({ ok: false, error: 'Faltan campos requeridos (nombre y contenido)' });
        }
        // Sanitizar slug
        if (slug) {
            slug = slug.trim().toLowerCase().replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '');
        }
        if (!slug) {
            slug = name.trim().toLowerCase().replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '');
            if (!slug) {
                slug = 'site-' + Date.now();
            }
        }
        const exists = dbSqlite.prepare('SELECT id FROM websites WHERE slug = ?').get(slug);
        if (exists) {
            return res.status(400).json({ ok: false, error: 'Ya existe un sitio con esa ruta' });
        }
        const stmt = dbSqlite.prepare('INSERT INTO websites (name, slug, content) VALUES (?, ?, ?)');
        stmt.run(name, slug, content);
        invalidateCache();
        io.emit('data_update', getDB());
        res.json({ ok: true });
    } catch (err) {
        console.error('Error en POST /api/websites:', err);
        res.status(500).json({ ok: false, error: 'Error interno del servidor: ' + err.message });
    }
});

app.put('/api/websites/:id', checkAuth, (req, res) => {
    try {
        const { id } = req.params;
        let { name, slug, content } = req.body;
        if (!name || !content) {
            return res.status(400).json({ ok: false, error: 'Faltan campos requeridos (nombre y contenido)' });
        }
        // Sanitizar slug
        if (slug) {
            slug = slug.trim().toLowerCase().replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '');
        }
        if (!slug) {
            slug = name.trim().toLowerCase().replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '');
            if (!slug) {
                slug = 'site-' + Date.now();
            }
        }
        const exists = dbSqlite.prepare('SELECT id FROM websites WHERE slug = ? AND id != ?').get(slug, id);
        if (exists) {
            return res.status(400).json({ ok: false, error: 'Ya existe un sitio con esa ruta' });
        }
        // CORREGIDO: usar comillas simples para 'now'
        const stmt = dbSqlite.prepare(`UPDATE websites SET name = ?, slug = ?, content = ?, updated_at = datetime('now', 'localtime') WHERE id = ?`);
        stmt.run(name, slug, content, id);
        invalidateCache();
        io.emit('data_update', getDB());
        res.json({ ok: true });
    } catch (err) {
        console.error('Error en PUT /api/websites/:id:', err);
        res.status(500).json({ ok: false, error: 'Error interno del servidor: ' + err.message });
    }
});

app.delete('/api/websites/:id', checkAuth, (req, res) => {
    try {
        const { id } = req.params;
        dbSqlite.prepare('DELETE FROM websites WHERE id = ?').run(id);
        invalidateCache();
        io.emit('data_update', getDB());
        res.json({ ok: true });
    } catch (err) {
        console.error('Error en DELETE /api/websites/:id:', err);
        res.status(500).json({ ok: false, error: 'Error interno del servidor: ' + err.message });
    }
});

// === Servir sitios web estáticos (público) ===
app.get('/:slug', (req, res) => {
    const slug = req.params.slug;
    if (slug === 'login' || slug === 'api' || slug === 'socket.io' || slug === 'media' || slug === 'favicon.ico') {
        return res.status(404).send('Not found');
    }
    try {
        const website = dbSqlite.prepare('SELECT content FROM websites WHERE slug = ?').get(slug);
        if (website) {
            res.send(website.content);
        } else {
            res.status(404).send('Sitio no encontrado');
        }
    } catch (e) {
        res.status(500).send('Error al cargar el sitio');
    }
});

app.post('/api/train', checkAuth, upload.array('media', 1), (req, res) => {
    const { id, key, response } = req.body;
    const paths = req.files ? req.files.map(f => f.path) : [];
    const types = req.files ? req.files.map(f => f.mimetype) : [];
    if (id) {
        dbSqlite.prepare('UPDATE training SET key = ?, response = ?, mediaPaths = ?, mediaTypes = ? WHERE id = ?')
            .run(key, response, JSON.stringify(paths), JSON.stringify(types), id);
    } else {
        dbSqlite.prepare('INSERT INTO training (key, response, mediaPaths, mediaTypes) VALUES (?, ?, ?, ?)')
            .run(key, response, JSON.stringify(paths), JSON.stringify(types));
    }
    invalidateCache();
    io.emit('data_update', getDB());
    res.json({ ok: true });
});

app.delete('/api/train/:id', checkAuth, (req, res) => {
    dbSqlite.prepare('DELETE FROM training WHERE id = ?').run(req.params.id);
    invalidateCache();
    io.emit('data_update', getDB());
    res.json({ ok: true });
});

