// SISTEMA DE COLA SECUENCIAL DE CONSULTAS DE IA (Evita la congelación de CPU/I/O)
class AIQueue {
    constructor() {
        this.queue = [];
        this.running = false;
    }

    push(task) {
        return new Promise((resolve, reject) => {
            this.queue.push({ task, resolve, reject });
            this.next();
        });
    }

    async next() {
        if (this.running || this.queue.length === 0) return;
        this.running = true;
        const { task, resolve, reject } = this.queue.shift();
        try {
            const result = await task();
            resolve(result);
        } catch (err) {
            reject(err);
        } finally {
            this.running = false;
            // Pequeño retardo entre ejecuciones de IA para enfriamiento de CPU
            setTimeout(() => this.next(), 250);
        }
    }
}
