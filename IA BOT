            <div id="p-rem" class="page"><h2 class="text-3xl font-black font-outfit gradient-text mb-6">Programar Mensajes</h2><div class="glass-card p-6 rounded-3xl mb-6"><input type="hidden" id="r-id"><div class="grid grid-cols-1 md:grid-cols-2 gap-4"><div><label class="text-[11px] text-zinc-400 font-semibold mb-1 block">Identificador del Cliente</label><input type="text" id="r-name" placeholder="Ej: Juan Pérez"></div><div><label class="text-[11px] text-zinc-400 font-semibold mb-1 block">Número de Destinatario</label><div class="flex gap-2"><input type="text" id="r-phone" placeholder="Ej: 18091234567"><button type="button" onclick="openContactModal('r-phone', 'r-name')" class="p-3 bg-zinc-900 border border-white/5 rounded-2xl text-zinc-400 hover:text-white transition-all"><i data-lucide="users" class="w-5 h-5"></i></button></div></div><div class="md:col-span-2"><label class="text-[11px] text-zinc-400 font-semibold mb-1 block">Mensaje Programado</label><textarea id="r-msg" placeholder="Escribe el mensaje..." rows="2"></textarea></div><div><label class="text-[11px] text-zinc-400 font-semibold mb-1 block">Frecuencia</label><select id="r-freq"><option>Una vez</option><option>Diario</option><option>Semanal</option><option>Mensual</option><option>Anual</option></select></div><div><label class="text-[11px] text-zinc-400 font-semibold mb-1 block">Fecha y Hora de Envío</label><input type="datetime-local" id="r-date"></div></div><button onclick="saveRem()" class="mt-5 w-full py-4 bg-emerald-600 hover:bg-emerald-700 text-white font-bold rounded-2xl text-xs hover:shadow-lg hover:shadow-emerald-500/25 active:scale-95 transition-all flex items-center justify-center gap-2"><i data-lucide="clock" class="w-4 h-4"></i> Programar Envío</button></div><div id="l-rem" class="grid grid-cols-1 md:grid-cols-2 gap-4"></div></div>

            <div id="p-excl" class="page"><h2 class="text-3xl font-black font-outfit gradient-text mb-6">Contactos Excluidos</h2><div class="glass-card p-6 rounded-3xl"><div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6 items-end"><div class="md:col-span-1"><label class="text-[11px] text-zinc-400 font-semibold mb-1 block">Nombre del Contacto</label><input type="text" id="e-name" placeholder="Ej: Socio Distribuidor"></div><div class="md:col-span-1"><label class="text-[11px] text-zinc-400 font-semibold mb-1 block">Número de WhatsApp</label><div class="flex gap-2"><input type="text" id="e-phone" placeholder="Ej: 18091234567"><button type="button" onclick="openContactModal('e-phone', 'e-name')" class="p-3 bg-zinc-900 border border-white/5 rounded-2xl text-zinc-400 hover:text-white transition-all"><i data-lucide="users" class="w-5 h-5"></i></button></div></div><button onclick="saveExcl()" class="h-12 bg-white text-black font-bold rounded-2xl text-xs hover:bg-zinc-200 transition-all flex items-center justify-center gap-1.5"><i data-lucide="user-plus" class="w-4 h-4"></i> Excluir</button></div><div id="l-excl" class="space-y-2"></div></div></div>

            <div id="p-config" class="page"><h2 class="text-3xl font-black font-outfit gradient-text mb-6">Ajustes del Sistema</h2><div class="grid grid-cols-1 lg:grid-cols-2 gap-6"><div class="glass-card p-6 rounded-3xl lg:col-span-2"><div class="flex items-center justify-between mb-4"><h3 class="font-bold text-base text-zinc-300">Rendimiento del Servidor (Tiempo Real)</h3><span class="text-[10px] bg-blue-600/10 text-blue-400 px-2 py-1 rounded-md font-bold tracking-widest animate-pulse">LIVE</span></div><div class="grid grid-cols-1 md:grid-cols-3 gap-6"><div class="bg-zinc-950/40 border border-white/[0.02] p-4 rounded-2xl text-center"><p class="text-xs text-zinc-500 font-bold uppercase tracking-wider mb-2">Carga de CPU</p><div class="text-3xl font-black font-mono text-blue-400" id="live-cpu">0.0%</div><div class="w-full bg-zinc-900 h-2 rounded-full mt-3 overflow-hidden"><div class="bg-blue-500 h-full rounded-full transition-all duration-500" id="live-cpu-bar" style="width: 0%;"></div></div></div><div class="bg-zinc-950/40 border border-white/[0.02] p-4 rounded-2xl text-center"><p class="text-xs text-zinc-500 font-bold uppercase tracking-wider mb-2">Memoria RAM</p><div class="text-3xl font-black font-mono text-purple-400" id="live-ram">0.0%</div><div class="w-full bg-zinc-900 h-2 rounded-full mt-3 overflow-hidden"><div class="bg-purple-500 h-full rounded-full transition-all duration-500" id="live-ram-bar" style="width: 0%;"></div></div></div><div class="bg-zinc-950/40 border border-white/[0.02] p-4 rounded-2xl flex flex-col justify-between overflow-hidden"><p class="text-xs text-zinc-500 font-bold uppercase tracking-wider mb-2 text-center">Historial de carga</p><canvas id="performance-chart" class="w-full h-16 bg-transparent"></canvas></div></div></div>
            
            <div class="glass-card p-6 rounded-3xl"><h3 class="font-bold text-base mb-4 text-zinc-300">Credenciales del Panel</h3><div class="space-y-4"><input type="text" id="conf-user" placeholder="Usuario maestro"><input type="password" id="conf-pass" placeholder="Contraseña de acceso"><button onclick="saveCredentials()" class="w-full py-4 text-white gradient-accent font-bold rounded-2xl text-xs flex items-center justify-center gap-2"><i data-lucide="key" class="w-4 h-4"></i> Guardar Credenciales</button></div></div><div class="glass-card p-6 rounded-3xl"><h3 class="font-bold text-base mb-4 text-zinc-300 font-outfit">Copias de Seguridad</h3><div class="space-y-4"><div class="flex gap-2"><input type="text" id="conf-backup-phone" placeholder="Número backup (Ej: 18091234567)"><button onclick="openContactModal('conf-backup-phone', null)" class="p-3 bg-zinc-900 border border-white/5 rounded-2xl text-zinc-400 hover:text-white"><i data-lucide="users" class="w-5 h-5"></i></button><button onclick="saveBackupPhone()" class="px-5 bg-emerald-600/10 hover:bg-emerald-600/20 border border-emerald-500/30 text-emerald-400 font-bold rounded-2xl text-xs">Guardar</button></div><div class="grid grid-cols-3 gap-2"><button onclick="downloadBackup()" class="py-3 bg-blue-600/10 hover:bg-blue-600/20 border border-blue-500/20 text-blue-400 font-bold rounded-xl text-xs flex items-center justify-center gap-1.5"><i data-lucide="download" class="w-4.5 h-4.5"></i> Descargar</button><button onclick="sendBackupManually()" class="py-3 bg-purple-600/10 hover:bg-purple-600/20 border border-purple-500/20 text-purple-400 font-bold rounded-xl text-xs flex items-center justify-center gap-1.5"><i data-lucide="send" class="w-4.5 h-4.5"></i> Enviar WA</button><button onclick="document.getElementById('restore-file').click()" class="py-3 bg-orange-600/10 border border-orange-500/20 text-orange-400 font-bold hover:bg-orange-600/20 rounded-xl text-xs flex items-center justify-center gap-1.5"><i data-lucide="upload" class="w-4.5 h-4.5"></i> Restaurar</button><input type="file" id="restore-file" accept=".json" class="hidden" onchange="restoreBackup(this)"></div></div></div><div class="glass-card p-6 rounded-3xl lg:col-span-2"><h3 class="font-bold text-base mb-5 text-zinc-300">Tiempos y Parámetros</h3><div class="grid md:grid-cols-2 gap-6 mb-6"><div class="space-y-2"><div class="flex justify-between text-xs font-bold text-zinc-400"><span>Retardo antes de responder (segundos)</span><span id="delay-value" class="text-blue-400 font-mono">0.0 s</span></div><input type="range" id="response-delay" min="0" max="10" step="0.5" value="0" class="w-full"></div><div class="space-y-2"><div class="flex justify-between text-xs font-bold text-zinc-400"><span>Intervalo cola (milisegundos)</span><span id="interval-value" class="text-orange-400 font-mono">3000 ms</span></div><input type="range" id="queue-interval" min="500" max="10000" step="100" value="3000" class="w-full"></div></div><div class="mb-6"><div class="flex justify-between text-xs font-bold text-zinc-400 mb-2"><span>Eliminar mensajes no reconocidos después de (horas)</span><span id="delete-hours-value" class="text-emerald-400 font-mono">168 h</span></div><input type="range" id="delete-learning-hours" min="1" max="720" step="1" value="168" class="w-full"><p class="text-[10px] text-zinc-500 mt-1">Configura cada cuántas horas se borrarán automáticamente los mensajes de la sección "Aprender".</p></div><button onclick="saveConfiguracionEnvio()" class="w-full py-4 text-white gradient-accent font-bold rounded-2xl text-xs flex items-center justify-center gap-2"><i data-lucide="save" class="w-4.5 h-4.5"></i> Guardar Configuración</button></div></div></div>
        </div>
    </main>

    <div id="contactModal" class="fixed inset-0 bg-black/80 backdrop-blur-sm hidden items-center justify-center z-50 p-4" onclick="if(event.target===this) closeContactModal()"><div class="glass-panel w-full max-w-sm rounded-3xl p-6 shadow-2xl relative animate-[fadeIn_0.2s_ease-out]"><h3 class="text-base font-bold text-white mb-4 flex items-center gap-2"><i data-lucide="users" class="w-5 h-5 text-blue-500"></i> Seleccionar Contacto</h3><input type="text" id="contactSearch" placeholder="Buscar por nombre o número..." class="mb-4"><div id="contactList" class="max-h-72 overflow-y-auto space-y-1 pr-1"></div><button onclick="closeContactModal()" class="mt-4 w-full py-3 bg-zinc-900 border border-white/5 hover:bg-zinc-800 rounded-2xl font-bold text-xs text-zinc-300">Cerrar</button></div></div>

    <script>
        const socket = io();
        let db = { training:[], learning:[], reminders:[], excluded:[], stats:{ replied:0, total:0 }, aiPrompts:[], backupPhone:'', responseDelay:0, queueInterval:3000, autoDeleteLearningHours:168 };
        let currentMediaType = 'text';
        let currentAIMediaType = 'image';
        let selectedFiles = [];
        let contacts = [];
        let activePhoneField = null, activeNameField = null;
        let cpuHistory = Array(20).fill(5);
        let configPageOpen = false;
        let chartCanvas = null, chartCtx = null;

        socket.on('sys_stats', data => {
            const cpuEl = document.getElementById('live-cpu');
            const cpuBar = document.getElementById('live-cpu-bar');
            const ramEl = document.getElementById('live-ram');
            const ramBar = document.getElementById('live-ram-bar');
            if (cpuEl) cpuEl.innerText = `${data.cpu}%`;
            if (cpuBar) cpuBar.style.width = `${data.cpu}%`;
            if (ramEl) ramEl.innerText = `${data.ram}%`;
            if (ramBar) ramBar.style.width = `${data.ram}%`;
            cpuHistory.push(data.cpu);
            cpuHistory.shift();
            if (configPageOpen) drawPerformanceChart();
        });

        function drawPerformanceChart() {
            if (!chartCanvas || !chartCtx) {
                chartCanvas = document.getElementById('performance-chart');
                if (!chartCanvas) return;
                chartCtx = chartCanvas.getContext('2d');
            }
            if (chartCanvas.width !== chartCanvas.clientWidth) {
                chartCanvas.width = chartCanvas.clientWidth;
                chartCanvas.height = 64;
            }
            chartCtx.clearRect(0, 0, chartCanvas.width, chartCanvas.height);
            chartCtx.strokeStyle = '#3b82f6';
            chartCtx.lineWidth = 2;
            chartCtx.beginPath();
            const step = chartCanvas.width / (cpuHistory.length - 1);
            for (let i = 0; i < cpuHistory.length; i++) {
                const x = i * step;
                const y = chartCanvas.height - (cpuHistory[i] / 100 * chartCanvas.height);
                if (i === 0) chartCtx.moveTo(x, y);
                else chartCtx.lineTo(x, y);
            }
            chartCtx.stroke();
        }

        function showToast(msg) { const t = document.getElementById('toast'); const tm = document.getElementById('toast-message'); tm.textContent = msg; t.classList.remove('opacity-0', 'translate-y-20'); t.classList.add('opacity-100', 'translate-y-0'); setTimeout(() => { t.classList.add('opacity-0', 'translate-y-20'); t.classList.remove('opacity-100', 'translate-y-0'); }, 3000); }
        function toggleSidebar() { document.getElementById('sidebar').classList.toggle('-translate-x-full'); }
        function closeMobileSidebar() { if (window.innerWidth < 1024) document.getElementById('sidebar').classList.add('-translate-x-full'); }
        document.addEventListener('click', function(event) { const sidebar = document.getElementById('sidebar'); const menuBtn = document.querySelector('header button'); if (window.innerWidth < 1024 && sidebar) { if (!sidebar.contains(event.target) && event.target !== menuBtn && (menuBtn && !menuBtn.contains(event.target))) sidebar.classList.add('-translate-x-full'); } });
        function nav(id) { document.querySelectorAll('.page').forEach(p => p.classList.remove('active')); document.getElementById('p-' + id).classList.add('active'); document.querySelectorAll('.sidebar-item').forEach(i => i.classList.remove('active')); document.getElementById('n-' + id).classList.add('active'); lucide.createIcons(); configPageOpen = (id === 'config'); if (configPageOpen) { setTimeout(() => { if (chartCanvas) drawPerformanceChart(); else drawPerformanceChart(); }, 100); } }
        
        function format12Hour(date) {
            let hours = date.getHours();
            let minutes = date.getMinutes();
            let seconds = date.getSeconds();
            const ampm = hours >= 12 ? 'PM' : 'AM';
            hours = hours % 12;
            hours = hours ? hours : 12;
            minutes = minutes < 10 ? '0' + minutes : minutes;
            seconds = seconds < 10 ? '0' + seconds : seconds;
            return `${hours}:${minutes}:${seconds} ${ampm}`;
        }

        function updateClock() { 
            const now = new Date(); 
            document.getElementById('clock-time').textContent = format12Hour(now); 
            document.getElementById('clock-date').textContent = now.toLocaleDateString('es-ES', { timeZone:'America/Santo_Domingo', weekday:'long', year:'numeric', month:'long', day:'numeric' }); 
        }
        setInterval(updateClock, 1000); updateClock();

        function openContactModal(phoneField, nameField) { activePhoneField = phoneField; activeNameField = nameField; document.getElementById('contactModal').classList.remove('hidden'); document.getElementById('contactModal').classList.add('flex'); renderContactList(); }
        function closeContactModal() { document.getElementById('contactModal').classList.remove('flex'); document.getElementById('contactModal').classList.add('hidden'); activePhoneField = null; }
        
        function renderContactList() { 
            const search = document.getElementById('contactSearch').value.toLowerCase().trim(); 
            const filtered = contacts.filter(c => (c.name && c.name.toLowerCase().includes(search)) || (c.number && c.number.includes(search))); 
            const list = document.getElementById('contactList'); 
            if (!filtered.length) { 
                list.innerHTML = '<div class="text-center py-6 text-xs text-zinc-600 font-medium">No se encontraron contactos</div>'; 
                return; 
            } 
            list.innerHTML = filtered.map(c => `
                <div class="p-3 bg-zinc-950/40 border border-white/[0.02] rounded-xl cursor-pointer hover:bg-white/5 transition-all" onclick="selectContact('${c.number}','${c.name.replace(/'/g, "\\'")}')">
                    <div class="font-bold text-xs text-zinc-100">${escapeHtml(c.name) || 'Sin Nombre'}</div>
                    <div class="text-[10px] text-zinc-500 font-mono mt-0.5">+${c.number}</div>
                </div>
            `).join(''); 
        }

        function selectContact(number, name) { 
            if (activePhoneField) document.getElementById(activePhoneField).value = number; 
            if (activeNameField && document.getElementById(activeNameField)) document.getElementById(activeNameField).value = name; 
            closeContactModal(); 
        }

        document.getElementById('contactSearch').addEventListener('input', renderContactList);
        socket.on('contacts_update', data => { contacts = data; if (!document.getElementById('contactModal').classList.contains('hidden')) renderContactList(); });
        
        function setMediaType(type) { currentMediaType = type; document.querySelectorAll('.media-type-btn').forEach(b => b.classList.remove('active')); document.getElementById('mt-' + type).classList.add('active'); document.getElementById('media-upload').classList.toggle('hidden', type === 'text'); if (type !== 'text') document.getElementById('t-media').accept = type === 'image' ? 'image/*' : 'video/*'; }
        document.getElementById('t-media').addEventListener('change', function(e) { selectedFiles = Array.from(e.target.files); const preview = document.getElementById('media-preview'); preview.innerHTML = ''; selectedFiles.forEach(f => { const reader = new FileReader(); reader.onload = ev => { const img = document.createElement('img'); img.src = ev.target.result; img.className = 'w-16 h-16 object-cover rounded-lg border border-white/10'; preview.appendChild(img); }; reader.readAsDataURL(f); }); });
        
        function setAIMediaType(type) {
            currentAIMediaType = type;
            document.getElementById('ai-mt-image').classList.toggle('active', type === 'image');
            document.getElementById('ai-mt-none').classList.toggle('active', type === 'none');
            document.getElementById('ai-media-upload').style.display = type === 'image' ? 'block' : 'none';
        }
        document.getElementById('ap-media').addEventListener('change', function(e) {
            const preview = document.getElementById('ai-media-preview');
            preview.innerHTML = '';
            if (e.target.files.length) {
                const reader = new FileReader();
                reader.onload = ev => {
                    const img = document.createElement('img');
                    img.src = ev.target.result;
                    img.className = 'w-16 h-16 object-cover rounded-lg border border-white/10';
                    preview.appendChild(img);
                };
                reader.readAsDataURL(e.target.files[0]);
            }
        });

        socket.on('connection_status', data => { const qrDiv = document.getElementById('qr-container'); const connDiv = document.getElementById('connected-container'); const logoutBtn = document.getElementById('btn-logout-wa'); const dot = document.getElementById('dot'); if (data.connected) { qrDiv.style.display = 'none'; connDiv.style.display = 'block'; logoutBtn.style.display = 'flex'; document.getElementById('bot-status').textContent = 'Conectado'; dot.className = 'w-3.5 h-3.5 rounded-full bg-emerald-500 shadow-[0_0_8px_#10b981]'; } else { qrDiv.style.display = 'flex'; connDiv.style.display = 'none'; logoutBtn.style.display = 'none'; document.getElementById('bot-status').textContent = data.status || 'Desconectado'; dot.className = 'w-3.5 h-3.5 rounded-full bg-red-500 animate-pulse shadow-[0_0_8px_#ef4444]'; } });
        socket.on('qr_update', url => { document.getElementById('qr-img').innerHTML = `<img src="${url}" class="w-64 h-64 rounded-xl pointer-events-none mx-auto shadow-2xl border border-white/5 animate-[fadeIn_0.3s_ease-out]">`; });
        socket.on('qr_clear', () => { document.getElementById('qr-img').innerHTML = '<span class="text-zinc-500 font-bold">Esperando código QR...</span>'; });
        socket.on('data_update', data => { db = data; render(); });
        socket.on('config_update', cfg => { if (cfg.responseDelay !== undefined) { document.getElementById('response-delay').value = cfg.responseDelay; document.getElementById('delay-value').textContent = cfg.responseDelay.toFixed(1) + ' s'; } if (cfg.queueInterval !== undefined) { document.getElementById('queue-interval').value = cfg.queueInterval; document.getElementById('interval-value').textContent = cfg.queueInterval + ' ms'; } if (cfg.autoDeleteLearningHours !== undefined) { document.getElementById('delete-learning-hours').value = cfg.autoDeleteLearningHours; document.getElementById('delete-hours-value').textContent = cfg.autoDeleteLearningHours + ' h'; } });

        async function load() { 
            const res = await fetch('/api/data'); 
            if (res.status === 401) { location.href = '/login'; return; } 
            const data = await res.json(); 
            db = data; 
            document.getElementById('conf-backup-phone').value = data.backupPhone || ''; 
            document.getElementById('response-delay').value = data.responseDelay || 0; 
            document.getElementById('delay-value').textContent = (data.responseDelay || 0).toFixed(1) + ' s'; 
            document.getElementById('queue-interval').value = data.queueInterval || 3000; 
            document.getElementById('interval-value').textContent = (data.queueInterval || 3000) + ' ms'; 
            document.getElementById('delete-learning-hours').value = data.autoDeleteLearningHours || 168; 
            document.getElementById('delete-hours-value').textContent = (data.autoDeleteLearningHours || 168) + ' h'; 
            
            const aiEnabled = data.aiEnabled === true;
            document.getElementById('ai-enabled-toggle').checked = aiEnabled;
            document.getElementById('ai-status-text').innerHTML = aiEnabled ? '<span class="text-green-400">Activado</span>' : '<span class="text-red-400">Desactivado</span>';
            document.getElementById('ai-model').value = data.aiModel || 'qwen2.5:1.5b';
            document.getElementById('ai-default-prompt').value = data.aiDefaultPrompt || '';
            
            if (data.qrImage) document.getElementById('qr-img').innerHTML = `<img src="${data.qrImage}" class="w-64 h-64 rounded-xl pointer-events-none mx-auto shadow-2xl border border-white/5">`; 
            render(); 
            const contactsRes = await fetch('/api/contacts'); 
            contacts = await contactsRes.json(); 
            lucide.createIcons(); 
        }

        function renderWeeklyChart(totalMsgs) { const base = totalMsgs || 0; const distribution = { lun: Math.round(base * 0.16), mar: Math.round(base * 0.18), mie: Math.round(base * 0.13), jue: Math.round(base * 0.21), vie: Math.round(base * 0.24), sab: Math.round(base * 0.05), dom: Math.round(base * 0.03) }; const maxDayVal = Math.max(...Object.values(distribution), 10); document.getElementById('y-max-val').textContent = `${maxDayVal} msgs`; document.getElementById('y-mid-val').textContent = `${Math.round(maxDayVal / 2)} msgs`; document.getElementById('weekly-aggregate-total').textContent = `Total: ${base} msgs`; const days = ['lun','mar','mie','jue','vie','sab','dom']; days.forEach(day => { const dayVal = distribution[day]; const pct = Math.max(Math.round((dayVal / maxDayVal) * 100), 10); const bar = document.getElementById(`bar-${day}`); const tip = document.getElementById(`tip-${day}`); const val = document.getElementById(`val-${day}`); if (bar) bar.style.height = `${pct}%`; if (tip) tip.textContent = `${dayVal} msgs`; if (val) val.textContent = dayVal; }); }
        
        function render() { 
            const totalMessages = db.stats?.total || 0; 
            document.getElementById('s-replied').textContent = db.stats?.replied || 0; 
            document.getElementById('s-total').textContent = totalMessages; 
            const today = new Date().toISOString().slice(0,10); 
            const todayCount = (db.reminders || []).filter(r => r.date.startsWith(today)).length; 
            document.getElementById('today-reminders-count').textContent = todayCount; 
            renderWeeklyChart(totalMessages); 
            
            const upcomingRemindersContainer = document.getElementById('dashboard-upcoming-reminders'); 
            const activeReminders = (db.reminders || []).filter(r => new Date(r.date) >= new Date()).sort((a,b)=>new Date(a.date)-new Date(b.date)).slice(0,3); 
            upcomingRemindersContainer.innerHTML = activeReminders.length ? activeReminders.map(r => { 
                const rawDate = new Date(r.date);
                const dateString = rawDate.toLocaleDateString('es-ES', { month: 'short', day: 'numeric' });
                let hours = rawDate.getHours();
                const minutes = String(rawDate.getMinutes()).padStart(2, '0');
                const ampm = hours >= 12 ? 'PM' : 'AM';
                hours = hours % 12 || 12;
                const timeString = `${hours}:${minutes} ${ampm}`;
                return `
                    <div class="p-3 bg-zinc-950/50 border border-white/[0.02] rounded-xl flex items-center justify-between gap-3">
                        <div class="truncate">
                            <h4 class="text-xs font-bold text-zinc-200 truncate">${escapeHtml(r.name)}</h4>
                            <p class="text-[10px] text-zinc-500 mt-0.5 truncate">+${r.phone}</p>
                        </div>
                        <div class="text-right shrink-0">
                            <span class="inline-block px-2 py-0.5 bg-orange-500/10 text-orange-400 font-bold font-mono text-[9px] rounded-md">${dateString}, ${timeString}</span>
                        </div>
                    </div>
                `; 
            }).join('') : '<div class="text-center py-8 text-xs text-zinc-500 font-semibold">No hay envíos pendientes</div>'; 
            
            document.getElementById('l-train').innerHTML = (db.training || []).map(t => `
                <div class="glass-card p-5 rounded-2xl flex flex-col justify-between">
                    <div class="flex justify-between items-start">
                        <div>
                            <span class="px-2.5 py-1 bg-blue-500/10 text-blue-400 text-[10px] font-bold rounded-lg uppercase tracking-wider">Regla (ID: ${t.id})</span>
                            <h4 class="text-base font-bold text-white mt-2">"${escapeHtml(t.key)}"</h4>
                            <p class="text-xs text-zinc-400 mt-2 italic leading-relaxed">"${escapeHtml(t.response)}"</p>
                        </div>
                        <div class="flex items-center gap-1">
                            <button onclick="editT(${t.id})" class="p-1.5 text-zinc-400 hover:text-white rounded hover:bg-white/5"><i data-lucide="edit-3" class="w-4 h-4"></i></button>
