app.post('/api/backup/restore', checkAuth, upload.single('backup'), (req, res) => {
    try {
        const backupData = JSON.parse(fs.readFileSync(req.file.path, 'utf8'));
        if (backupData.training && backupData.reminders && backupData.excluded && backupData.learning && backupData.stats) {
            dbSqlite.prepare('DELETE FROM training').run();
            dbSqlite.prepare('DELETE FROM reminders').run();
            dbSqlite.prepare('DELETE FROM excluded').run();
            dbSqlite.prepare('DELETE FROM learning').run();
            dbSqlite.prepare('DELETE FROM stats').run();
            dbSqlite.prepare('DELETE FROM ai_prompts').run();
            
            const insertTrain = dbSqlite.prepare('INSERT INTO training (id, key, response, mediaPaths, mediaTypes) VALUES (?, ?, ?, ?, ?)');
            backupData.training.forEach(t => insertTrain.run(t.id, t.key, t.response, t.mediaPaths, t.mediaTypes));
            dbSqlite.prepare("UPDATE sqlite_sequence SET seq = (SELECT MAX(id) FROM training) WHERE name = 'training'").run();
            
            const insertRem = dbSqlite.prepare('INSERT INTO reminders (id, name, phone, message, freq, date) VALUES (?, ?, ?, ?, ?, ?)');
            backupData.reminders.forEach(r => insertRem.run(r.id, r.name, r.phone, r.message, r.freq, r.date));
            dbSqlite.prepare("UPDATE sqlite_sequence SET seq = (SELECT MAX(id) FROM reminders) WHERE name = 'reminders'").run();
            
            const insertExc = dbSqlite.prepare('INSERT INTO excluded (id, name, phone) VALUES (?, ?, ?)');
            backupData.excluded.forEach(e => insertExc.run(e.id, e.name, e.phone));
            dbSqlite.prepare("UPDATE sqlite_sequence SET seq = (SELECT MAX(id) FROM excluded) WHERE name = 'excluded'").run();
            
            const insertLearn = dbSqlite.prepare('INSERT INTO learning (id, text, from_phone, date, hasMedia, type, timestamp) VALUES (?, ?, ?, ?, ?, ?, ?)');
            backupData.learning.forEach(l => insertLearn.run(l.id, l.text, l.from_phone, l.date, l.hasMedia, l.type, l.timestamp || 0));
            dbSqlite.prepare("UPDATE sqlite_sequence SET seq = (SELECT MAX(id) FROM learning) WHERE name = 'learning'").run();
            
            const insertStats = dbSqlite.prepare('INSERT INTO stats (id, replied, total) VALUES (?, ?, ?)');
            backupData.stats.forEach(s => insertStats.run(s.id, s.replied, s.total));
            
            if (backupData.aiPrompts) {
                const insertAIPrompt = dbSqlite.prepare('INSERT INTO ai_prompts (id, key, prompt_text, mediaPaths, mediaTypes) VALUES (?, ?, ?, ?, ?)');
                backupData.aiPrompts.forEach(p => insertAIPrompt.run(p.id, p.key, p.prompt_text, p.mediaPaths, p.mediaTypes));
                dbSqlite.prepare("UPDATE sqlite_sequence SET seq = (SELECT MAX(id) FROM ai_prompts) WHERE name = 'ai_prompts'").run();
            }
            
            io.emit('data_update', getDB());
            res.json({ ok: true });
        } else {
            res.status(400).json({ ok: false, error: 'Formato de copia de seguridad incompatible.' });
        }
        fs.unlinkSync(req.file.path);
    } catch (e) {
        res.status(500).json({ ok: false, error: e.message });
    }
});

