                '--no-first-run',
                '--no-zygote',
                '--disable-extensions',
                '--disable-background-timer-throttling',
                '--disable-backgrounding-occluded-windows',
                '--disable-renderer-backgrounding',
                '--disable-accelerated-2d-canvas',
                '--disable-software-rasterizer'
            ]
        }
    });

    client.on('qr', (qr) => {
        botStatus = "Esperando QR";
        isConnected = false;
        lastQR = qr;
        qrcode.toDataURL(qr, (err, url) => {
            if (!err) {
                lastQRImage = url;
                io.emit('qr_update', url);
            }
            io.emit('connection_status', { connected: false, status: botStatus });
        });
        reconnectAttempts = 0;
    });

    client.on('ready', async () => {
        botStatus = "Conectado";
        isConnected = true;
        lastQR = null;
        lastQRImage = null;
        reconnectAttempts = 0;
        io.emit('qr_clear');
        io.emit('connection_status', { connected: true, status: botStatus });
        console.log('✅ Conexión establecida y lista.');
        
        try {
            const rawContacts = await client.getContacts();
            const uniqueMap = new Map();
            
            rawContacts.forEach(c => {
                if (c.id.server === 'c.us' && c.isUser === true && c.isMyContact === true && !c.isGroup) {
                    const normNum = normalizePhone(c.number || c.id.user);
                    if (normNum && normNum.length >= 9 && normNum.length <= 15) {
                        if (!uniqueMap.has(normNum)) {
                            uniqueMap.set(normNum, {
                                id: c.id._serialized,
                                name: (c.name || c.pushname || normNum).trim(),
                                number: normNum
                            });
                        }
                    }
                }
            });
            
            contacts = Array.from(uniqueMap.values()).sort((a,b) => a.name.localeCompare(b.name));
            io.emit('contacts_update', contacts);
        } catch (e) {
            console.error("⚠️ Error filtrando contactos de WhatsApp:", e.message);
        }
    });

    client.on('disconnected', async () => {
        botStatus = "Desconectado";
        isConnected = false;
        lastQR = null;
        lastQRImage = null;
        contacts = [];
        io.emit('qr_clear');
        io.emit('connection_status', { connected: false, status: botStatus });
        scheduleReconnect();
    });

    client.on('message', async (msg) => {
        try {
            if (msg.from === 'status@broadcast') return;
            if (msg.type !== 'chat' && msg.type !== 'image' && msg.type !== 'video') return;
            if (!msg.body || typeof msg.body !== 'string') return;

            const db = getDB();
            let phone = normalizePhone(msg.from);
            
            if (phone.length < 9 || phone.length > 15) return;
            if (db.excluded.some(ex => phone.includes(ex.phone))) return;

            const text = msg.body.toLowerCase().trim();
            
            // 1. Coincidencia directa de Regla de Entrenamiento
            const trigger = db.training.find(t => {
                const key = t.key.toLowerCase().trim();
                return text === key || text.includes(key);
            });

            if (trigger) {
                const conf = getConfig();
                if (conf.responseDelay > 0) await new Promise(r => setTimeout(r, conf.responseDelay * 1000));
                
                if (trigger.mediaPaths && JSON.parse(trigger.mediaPaths).length > 0) {
                    const paths = JSON.parse(trigger.mediaPaths);
                    const media = MessageMedia.fromFilePath(paths[0]);
                    messageQueue.enqueue(msg.from, media, { caption: trigger.response });
                } else {
                    messageQueue.enqueue(msg.from, trigger.response);
                }
                updateStats(1, 0);
            } 
            else if (!msg.from.includes('@g.us')) {
                // Guardar en el historial contextual antes de procesar
                saveToChatHistory(phone, 'user', msg.body);
                
                // 2. Coincidencia por Prompt Personalizado (Sección Respuesta IA)
                const customPrompt = getCustomPrompt(msg.body);
                
                // 3. Consultar la IA Local secuencial con Cola integrada
                const respuestaIA = await consultarOllama(phone, msg.body, customPrompt);

                if (respuestaIA) {
                    let textoFinal = respuestaIA;
                    let idReglaMultimedia = null;

                    const matchTag = respuestaIA.match(/\[ENVIAR_IMAGEN:\s*(\d+)\]/);
                    if (matchTag) {
                        idReglaMultimedia = parseInt(matchTag[1]);
                        textoFinal = respuestaIA.replace(/\[ENVIAR_IMAGEN:\s*\d+\]/g, '').trim();
                    }

                    saveToChatHistory(phone, 'assistant', textoFinal);

                    if (customPrompt && customPrompt.mediaPaths.length > 0) {
                        const mediaPath = customPrompt.mediaPaths[0];
                        if (fs.existsSync(mediaPath)) {
                            const media = MessageMedia.fromFilePath(mediaPath);
                            messageQueue.enqueue(msg.from, media, { caption: textoFinal });
                        } else {
                            messageQueue.enqueue(msg.from, textoFinal);
                        }
                    } 
                    else if (idReglaMultimedia) {
                        const regla = db.training.find(t => t.id === idReglaMultimedia);
                        if (regla && regla.mediaPaths) {
                            const paths = JSON.parse(regla.mediaPaths);
                            if (paths.length > 0 && fs.existsSync(paths[0])) {
                                const media = MessageMedia.fromFilePath(paths[0]);
                                messageQueue.enqueue(msg.from, media, { caption: textoFinal });
                            } else {
                                messageQueue.enqueue(msg.from, textoFinal);
                            }
                        } else {
                            messageQueue.enqueue(msg.from, textoFinal);
                        }
                    } else {
                        messageQueue.enqueue(msg.from, textoFinal);
                    }
                    updateStats(1, 0);
                } else {
                    // IA inactiva, caída o con timeout de 30s excedido: Registro para aprendizaje manual
                    const exists = db.learning.some(l => l.text === msg.body && l.from_phone === phone);
                    if (!exists) {
                        const stmt = dbSqlite.prepare('INSERT INTO learning (text, from_phone, date, hasMedia, type, timestamp) VALUES (?, ?, ?, ?, ?, ?)');
                        stmt.run(
                            msg.body, 
                            phone, 
                            moment().tz(TZ).format('DD/MM/YYYY hh:mm A'), 
                            msg.hasMedia ? 1 : 0, 
                            msg.type, 
                            Math.floor(Date.now() / 1000)
                        );
                    }
                }
            }
            updateStats(0, 1);
            io.emit('data_update', getDB());
        } catch (e) {
            console.error("⚠️ Error al procesar mensaje entrante:", e.message);
        }
    });

    client.initialize().catch(e => {
        console.error("Fallo critico al inicializar cliente:", e.message);
        botStatus = "Error de inicio";
        io.emit('connection_status', { connected: false, status: botStatus });
        scheduleReconnect();
    });
}

function autoDeleteOldLearning() {
    const config = getConfig();
    const hours = config.autoDeleteLearningHours || 168;
    const secondsAgo = hours * 3600;
    const cutoffTimestamp = Math.floor(Date.now() / 1000) - secondsAgo;
    const deleted = dbSqlite.prepare('DELETE FROM learning WHERE timestamp < ?').run(cutoffTimestamp);
    if (deleted.changes > 0) {
        console.log(`🗑️ Mantenimiento de almacenamiento: ${deleted.changes} mensajes antiguos purgados.`);
        io.emit('data_update', getDB());
    }
}
