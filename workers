    <script>
        // Función limpia de copiado al portapapeles con compatibilidad avanzada
        function copyData(value, label, triggerElement = null) {
            const tempInput = document.createElement('textarea');
            tempInput.value = value;
            tempInput.style.position = 'fixed';
            tempInput.style.opacity = '0';
            document.body.appendChild(tempInput);
            tempInput.select();
            
            try {
                const successful = document.execCommand('copy');
                if (successful) {
                    showToast(`Copiado con éxito`, `${label} copiado.`);
                    
                    // Si el clic viene de una tarjeta, modificamos el botón correspondiente dentro de ella
                    if (triggerElement) {
                        const card = triggerElement.closest('.glass-card') || triggerElement;
                        const btn = card.querySelector('.btn-copy');
                        if (btn) {
                            const originalContent = btn.innerHTML;
                            
                            // Cambia la apariencia del botón a éxito
                            btn.classList.add('copied');
                            btn.innerHTML = `
                                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"></path>
                                </svg>
                                <span>¡Copiado!</span>
                            `;
                            
                            // Revertir a la normalidad después de un breve lapso
                            setTimeout(() => {
                                btn.classList.remove('copied');
                                btn.innerHTML = originalContent;
                            }, 2000);
                        }
                    }
                } else {
                    showToast("Error", "No se pudo copiar automáticamente.", "error");
                }
            } catch (err) {
                showToast("Acción no soportada", "Por favor copia el texto manualmente.", "error");
            }
            
            document.body.removeChild(tempInput);
        }

        // Mostrar notificación tipo Toast limpia
        function showToast(title, message, status = "success") {
            const container = document.getElementById('toast-container');
            const toast = document.createElement('div');
            
            toast.className = 'toast p-3.5 rounded-2xl shadow-xl flex items-center gap-3 w-full';
            
            let colorIconClass = 'text-emerald-400 bg-emerald-500/10';
            let iconMarkup = `
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"></path>
                </svg>
            `;

            if (status === 'error') {
                colorIconClass = 'text-red-400 bg-red-500/10';
                iconMarkup = `
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path>
                    </svg>
                `;
            }

            toast.innerHTML = `
                <div class="p-1.5 rounded-lg ${colorIconClass} flex-shrink-0">
                    ${iconMarkup}
                </div>
                <div class="flex-grow">
                    <p class="text-xs font-bold text-white">${title}</p>
                    <p class="text-[10px] text-gray-400 mt-0.5">${message}</p>
                </div>
            `;

            container.appendChild(toast);

            // Transición de entrada
            setTimeout(() => {
                toast.classList.add('show');
            }, 50);

            // Auto-eliminación del DOM
            setTimeout(() => {
                toast.classList.remove('show');
                setTimeout(() => {
                    toast.remove();
                }, 400);
            }, 2500);
        }
    </script>
